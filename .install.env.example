# Dokploy Wizard install env example
# Copy this file to .install.env, fill in operator-owned values, then chmod 0600.
# Keep .install.env private. Do not commit real passwords, tokens, API keys, or generated state secrets.

## Core stack identity
STACK_NAME=wizard-stack
ROOT_DOMAIN=example.com
PACKS=nextcloud,openclaw,my-farm-advisor,seaweedfs,coder,docuseal,surfsense

## Cloudflare operator credentials
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CLOUDFLARE_ZONE_ID=<cloudflare-zone-id>
CLOUDFLARE_API_TOKEN=<cloudflare-api-token>
CLOUDFLARE_ACCESS_OTP_EMAILS=operator@example.com

## Dokploy bootstrap
DOKPLOY_SUBDOMAIN=dokploy
DOKPLOY_ADMIN_EMAIL=operator@example.com
DOKPLOY_ADMIN_PASSWORD=<strong-dokploy-admin-password>
# Generated/state-backed after bootstrap. Leave empty for normal installs.
DOKPLOY_API_URL=
DOKPLOY_API_KEY=
DOKPLOY_PASSWORD=

## Optional Docker Hub auth
# Set both values to avoid unauthenticated Docker Hub pull-rate limits during install/proof.
DOCKER_USERNAME=<your-dockerhub-username>
DOCKER_PAT=<your-dockerhub-pat>

## Optional private host access
ENABLE_HEADSCALE=true
ENABLE_TAILSCALE=false
TAILSCALE_AUTH_KEY=<tailscale-auth-key-optional>
TAILSCALE_HOSTNAME=

## LiteLLM shared gateway upstream inputs
# Upstream provider keys terminate at LiteLLM. App packs receive wizard-managed virtual keys.
AI_DEFAULT_PROVIDER=tuxdesktop.tailb12aa5.ts.net
AI_DEFAULT_MODEL=unsloth-active
LITELLM_LOCAL_BASE_URL=http://tuxdesktop.tailb12aa5.ts.net:61434/v1
LITELLM_LOCAL_MODEL=unsloth-active
LITELLM_LOCAL_API_KEY=<local-model-api-key-optional>
LITELLM_OPENROUTER_API_KEY=<openrouter-api-key-optional>
LITELLM_OPENROUTER_MODELS=openrouter/hunter-alpha=openrouter/openai/gpt-4.1-mini
LITELLM_OPENCODE_GO_API_KEY=<opencode-go-api-key-optional>
LITELLM_OPENCODE_GO_WILDCARD=false
LITELLM_NVIDIA_API_KEY=<nvidia-api-key-optional>

## Nextcloud / Nexa runtime integration
NEXTCLOUD_OPENCLAW_RESCAN_CRON=0 */6 * * *
NEXTCLOUD_OPENCLAW_RESCAN_TIMEZONE=UTC
OPENCLAW_NEXA_TALK_SHARED_SECRET=<nexa-talk-shared-secret-optional>
OPENCLAW_NEXA_TALK_SIGNING_SECRET=<nexa-talk-signing-secret-optional>
OPENCLAW_NEXA_ONLYOFFICE_CALLBACK_SECRET=<nexa-onlyoffice-callback-secret-optional>
OPENCLAW_NEXA_EDITOR_EVENTS_SHARED_SECRET=<nexa-editor-events-shared-secret-optional>
OPENCLAW_NEXA_PRESENCE_POLICY=trusted_proxy
OPENCLAW_NEXA_NEXTCLOUD_BASE_URL=
OPENCLAW_NEXA_WEBDAV_AUTH_USER=nexa
OPENCLAW_NEXA_WEBDAV_AUTH_PASSWORD=<nexa-webdav-password-optional>
OPENCLAW_NEXA_AGENT_USER_ID=nexa
OPENCLAW_NEXA_AGENT_DISPLAY_NAME=Nexa
OPENCLAW_NEXA_AGENT_PASSWORD=<nexa-agent-password-optional>
OPENCLAW_NEXA_AGENT_EMAIL=nexa@example.com
OPENCLAW_NEXA_MEM0_LLM_BASE_URL=
OPENCLAW_NEXA_MEM0_LLM_API_KEY=<nexa-mem0-api-key-optional>
OPENCLAW_NEXA_MEM0_EMBEDDER_MODEL=text-embedding-3-small
OPENCLAW_NEXA_MEM0_EMBEDDER_DIMENSIONS=1536
OPENCLAW_NEXA_MEM0_VECTOR_BACKEND=qdrant
OPENCLAW_NEXA_MEM0_VECTOR_DIMENSIONS=1536

## OpenClaw pack
OPENCLAW_CHANNELS=telegram
OPENCLAW_INTERNAL_SUBDOMAIN=openclaw-internal
OPENCLAW_REPLICAS=1
OPENCLAW_GATEWAY_PASSWORD=<openclaw-gateway-password-generated-or-optional>
OPENCLAW_GATEWAY_TOKEN=<openclaw-gateway-token-generated-or-optional>
OPENCLAW_NVIDIA_API_KEY=<openclaw-nvidia-api-key-optional>
OPENCLAW_TELEGRAM_BOT_TOKEN=<openclaw-telegram-bot-token-optional>
OPENCLAW_TELEGRAM_OWNER_USER_ID=

## My Farm Advisor pack
ENABLE_MY_FARM_ADVISOR=true
MY_FARM_ADVISOR_SUBDOMAIN=farm
MY_FARM_ADVISOR_CHANNELS=telegram
MY_FARM_ADVISOR_GATEWAY_PASSWORD=<my-farm-advisor-gateway-password-generated-or-optional>
TZ=UTC

## SeaweedFS pack
# Guided installs can generate these. Env-file installs may provide operator-owned S3 credentials.
SEAWEEDFS_ACCESS_KEY=<seaweedfs-access-key-generated-or-operator-provided>
SEAWEEDFS_SECRET_KEY=<seaweedfs-secret-key-generated-or-operator-provided>

## Coder pack
CODER_WILDCARD_SUBDOMAIN=coder

## SurfSense pack
SURFSENSE_SUBDOMAIN=surfsense
SURFSENSE_API_SUBDOMAIN=surfsense-api
SURFSENSE_ZERO_SUBDOMAIN=surfsense-zero
SURFSENSE_VERSION=0.0.25

## SurfSense generated secrets, do not set for normal installs
# The wizard generates these values, stores them in state, and reuses them across reruns.
# They are documented here so operators know why they may appear in state or Dokploy env specs.
# Do not put real values for these keys in .install.env.example or committed files:
# - SURFSENSE_SECRET_KEY
# - SURFSENSE_JWT_SECRET
# - SURFSENSE_DB_PASSWORD
# - SURFSENSE_ZERO_ADMIN_PASSWORD
# - SURFSENSE_SEARXNG_SECRET
# - SURFSENSE_LITELLM_VIRTUAL_KEY
